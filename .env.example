# Where the app sends chat-completions requests. Defaults to the local
# backend proxy in backend/ (see backend/README.md).
VITE_API_URL=http://localhost:8787/v1/chat/completions

# Model name sent in the request body. The local backend/llama-server setup
# ignores this in single-model mode, but it's sent for compatibility.
VITE_MODEL=local-model

# TheSportsDB API key for get_game_result. Optional — defaults to their
# published free/shared demo key ("123") if unset, no registration needed.
VITE_SPORTSDB_KEY=
